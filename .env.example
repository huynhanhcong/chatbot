GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_GENERATION_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Use local embedded Qdrant data by default. If QDRANT_PATH is empty, QDRANT_URL is used.
QDRANT_URL=http://localhost:6333
QDRANT_PATH=Data_RAG/index/qdrant_local
QDRANT_COLLECTION=hanhphuc_hospital_rag
CHUNK_QDRANT_COLLECTION=hanhphuc_hospital_rag_chunks
RAG_USE_CHUNK_INDEX=true
ROUTER_LLM_ENABLED=false
RERANKER_PROVIDER=rrf_mmr

# Keep Redis disabled for local single-process development.
# Set USE_REDIS=true in staging/production so conversations survive multiple workers.
USE_REDIS=false
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=900

PHARMACITY_INDEX_PATH=Data_RAG/index/pharmacity_products.sqlite

# Voice AI expansion
VOICE_CHAT_API_URL=http://127.0.0.1:8000/chat
VOICE_STT_PROVIDER=browser
VOICE_TTS_PROVIDER=browser
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
GROQ_API_KEY=
